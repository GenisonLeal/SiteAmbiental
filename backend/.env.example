# ── Banco de Dados ─────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:senha@host:porta/nome_do_banco
# Exemplo local:  postgresql+asyncpg://postgres:senha@localhost:5432/protecta_db
# Exemplo Supabase: obtido em Project Settings > Database > Connection String (URI)
DATABASE_URL=

# ── Segurança JWT ──────────────────────────────────────────
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── E-mail SMTP (Gmail) ────────────────────────────────────
# Para usar com Gmail, crie uma "Senha de app" em:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Protecta Dedetização

# ── Supabase Storage ───────────────────────────────────────
# Obtidos em: Project Settings > API
SUPABASE_URL=
SUPABASE_KEY=

# ── Celery / Redis ─────────────────────────────────────────
# Local: redis://localhost:6379/0
# Railway/Redis Cloud: obtido no painel do serviço
REDIS_URL=redis://localhost:6379/0

# ── CORS ───────────────────────────────────────────────────
# Lista de origens permitidas em formato JSON
# Exemplo: ["http://localhost:5173","https://meusite.vercel.app"]
CORS_ORIGINS=["http://localhost:5173"]
